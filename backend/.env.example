# Server Configuration
PORT=5000
NODE_ENV=development

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=movies_to
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# API Base URL (for OAuth callbacks)
API_BASE_URL=http://localhost:5000

# OAuth Configuration
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# TMDB API (optional - for syncing movie data)
TMDB_API_KEY=your_tmdb_api_key_here
# TTL for movie sync cache in minutes
MOVIE_SYNC_TTL_MINUTES=60

# Email Service Configuration (Resend - recommended)
RESEND_API_KEY=
EMAIL_FROM=Movies.to <noreply@movies.to>

# Alternative: SMTP Configuration (if not using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Logging
LOG_LEVEL=info

# Redis Configuration (optional - for caching)
# Leave empty to run without Redis
REDIS_URL=
# Example: redis://localhost:6379
# For Redis Cloud/Heroku: REDIS_TLS_URL=rediss://...

# Stripe Configuration (optional - for premium subscriptions)
# Leave empty to run in trial mode without payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Torrent provider configuration
# Choose provider: 'yts' or 'custom'
TORRENT_PROVIDER=yts
# YTS domain preference (yts.mx or yts.lt). Fallback will be attempted automatically.
YTS_BASE_DOMAIN=yts.mx
# Cache TTL for torrents in minutes
TORRENT_CACHE_TTL_MINUTES=5
# Optional: custom provider base URL (used when TORRENT_PROVIDER=custom)
TORRENT_API_URL=
# Optional: comma-separated list of trackers to include in magnet links
TORRENT_TRACKERS=udp://tracker.openbittorrent.com:6969/announce,udp://tracker.opentracker.org:1337/announce,udp://exodus.desync.com:6969,udp://tracker.coppersurfer.tk:6969/announce
